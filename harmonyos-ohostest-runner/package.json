{
  "name": "harmonyos-ohostest-runner",
  "version": "0.1.2",
  "private": true,
  "type": "module",
  "description": "Standalone HarmonyOS ohosTest matrix runner.",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "ohostest:case": "node --import tsx scripts/runOhosTestCase.ts",
    "ohostest:matrix": "node --import tsx scripts/runOhosTestMatrix.ts",
    "lint": "eslint .",
    "test": "node --import tsx --test tests/*.test.ts",
    "format": "prettier --write \"src/**/*.ts\" \"scripts/**/*.ts\" \"tests/**/*.ts\" \"*.json\"",
    "deploy:fold": "node --import tsx scripts/deployFoldTrigger.ts"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "eslint": "^10.6.0",
    "prettier": "^3.8.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.62.1"
  }
}
